---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — La Prof Virginie" description="Contact Prof Virginie for inquiries about her personalized French courses, or to get more information on your French learning journey. Your path to mastering French is just a message away.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-20 overflow-hidden bg-cream">
    <div class="max-w-4xl mx-auto text-center px-6">
      <div class="reveal">
        <p class="text-gold text-sm font-semibold tracking-[0.25em] uppercase mb-3">Get In Touch</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-charcoal leading-tight mb-4">
          Let's <span class="text-gold">Connect</span>
        </h1>
        <p class="text-charcoal/60 text-lg max-w-xl mx-auto">
          For business enquiries, sponsorships, speaking engagements, or to start your French learning journey.
        </p>
      </div>
    </div>

    <!-- Decoration -->
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-gold/5 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-gold/8 rounded-full blur-[80px] pointer-events-none"></div>
  </section>

  <!-- ===== CONTACT FORM + PHOTO ===== -->
  <section class="section-padding relative overflow-hidden bg-cream">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- Form column -->
        <div class="reveal">
          <div class="glass-strong p-8 md:p-10">
            <h2 class="text-2xl font-bold text-charcoal mb-2">Send a Message</h2>
            <p class="text-charcoal/50 text-sm mb-8">I'll get back to you as soon as possible.</p>

            <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
              <!-- Web3Forms access key — replace with real key -->
              <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
              <input type="hidden" name="subject" value="New contact from La Prof Virginie website" />
              <input type="hidden" name="from_name" value="La Prof Virginie Website" />

              <!-- Honeypot spam protection -->
              <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-charcoal/70 mb-1.5">Name</label>
                <input
                  type="text" id="name" name="name" required
                  placeholder="Your name"
                  class="w-full px-4 py-3 rounded-xl bg-white/60 border border-white/40 text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold/50 transition-all backdrop-blur-sm"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-charcoal/70 mb-1.5">Email</label>
                <input
                  type="email" id="email" name="email" required
                  placeholder="your@email.com"
                  class="w-full px-4 py-3 rounded-xl bg-white/60 border border-white/40 text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold/50 transition-all backdrop-blur-sm"
                />
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-charcoal/70 mb-1.5">Message</label>
                <textarea
                  id="message" name="message" rows="5" required
                  placeholder="Tell me about your goals..."
                  class="w-full px-4 py-3 rounded-xl bg-white/60 border border-white/40 text-charcoal placeholder:text-charcoal/30 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold/50 transition-all backdrop-blur-sm resize-none"
                ></textarea>
              </div>

              <!-- Submit -->
              <button type="submit" class="btn-primary w-full justify-center text-base">
                Send Message
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              </button>
            </form>

            <!-- Success message (hidden by default, shown via JS) -->
            <div id="form-success" class="hidden mt-6 p-4 rounded-xl bg-gold/15 border border-gold/30 text-center">
              <p class="text-charcoal font-medium">Merci! Your message has been sent.</p>
              <p class="text-charcoal/60 text-sm mt-1">I'll get back to you shortly.</p>
            </div>
          </div>
        </div>

        <!-- Photo + Social column -->
        <div class="space-y-6 reveal" style="animation-delay: 0.15s;">
          <!-- Photo -->
          <div class="glass p-3">
            <img
              src="/images/contact-photo.jpg"
              alt="Virginie"
              class="w-full rounded-2xl object-cover max-h-[450px]"
            />
          </div>

          <!-- Or book a call -->
          <div class="glass-gold p-6 text-center">
            <h3 class="text-lg font-bold text-charcoal mb-2">Prefer to chat live?</h3>
            <p class="text-charcoal/60 text-sm mb-4">Book a free 15-minute call and let's discuss your goals.</p>
            <a href="https://calendly.com/laprofvirginie/15min" target="_blank" rel="noopener"
               class="btn-primary inline-flex">
              Book a Free Call
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>

          <!-- Social links -->
          <div class="glass p-6">
            <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-charcoal/40 mb-4 text-center">Follow Along</h3>
            <div class="flex items-center justify-center gap-4">
              <a href="https://www.instagram.com/laprofvirginie/" target="_blank" rel="noopener"
                 class="w-12 h-12 rounded-full border border-charcoal/10 flex items-center justify-center text-charcoal/50 hover:text-gold hover:border-gold/40 transition-all duration-300 hover:scale-110"
                 aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="https://www.tiktok.com/@laprofvirginie" target="_blank" rel="noopener"
                 class="w-12 h-12 rounded-full border border-charcoal/10 flex items-center justify-center text-charcoal/50 hover:text-gold hover:border-gold/40 transition-all duration-300 hover:scale-110"
                 aria-label="TikTok">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78c.27 0 .54.04.8.1v-3.5a6.37 6.37 0 0 0-.8-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.7a8.27 8.27 0 0 0 4.76 1.5v-3.5a4.84 4.84 0 0 1-1-.01z"/></svg>
              </a>
              <a href="https://www.facebook.com/laprofvirginie/" target="_blank" rel="noopener"
                 class="w-12 h-12 rounded-full border border-charcoal/10 flex items-center justify-center text-charcoal/50 hover:text-gold hover:border-gold/40 transition-all duration-300 hover:scale-110"
                 aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Decoration -->
    <div class="absolute top-40 -left-20 w-64 h-64 bg-gold/5 rounded-full blur-[100px] pointer-events-none"></div>
  </section>

  <Footer />
</Layout>

<script>
  // Simple form success handling
  const form = document.querySelector('form');
  const successMsg = document.getElementById('form-success');

  if (form && successMsg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });

        if (res.ok) {
          form.style.display = 'none';
          successMsg.classList.remove('hidden');
        }
      } catch {
        // Fallback: submit normally
        form.submit();
      }
    });
  }
</script>
