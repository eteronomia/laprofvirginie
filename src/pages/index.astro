  <!-- Testimonial video players — play/pause logic -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var cards = document.querySelectorAll('.video-testimonial-card');
      cards.forEach(function(card) {
        var video = card.querySelector('[data-testimonial-video]');
        var playBtn = card.querySelector('[data-play-btn]');
        var pauseBtn = card.querySelector('[data-pause-btn]');
        if (!video || !playBtn || !pauseBtn) return;

        function showPlay() {
          playBtn.style.display = 'flex';
          pauseBtn.classList.remove('visible');
        }
        function showPause() {
          playBtn.style.display = 'none';
          pauseBtn.classList.add('visible');
        }

        function doPlay() {
          // Pause all other testimonial videos first
          document.querySelectorAll('[data-testimonial-video]').forEach(function(v) {
            if (v !== video && !v.paused) {
              v.pause();
              var oc = v.closest('.video-testimonial-card');
              if (oc) {
                var op = oc.querySelector('[data-play-btn]');
                var ox = oc.querySelector('[data-pause-btn]');
                if (op) op.style.display = 'flex';
                if (ox) ox.classList.remove('visible');
              }
            }
          });
          video.muted = true;
          var promise = video.play();
          if (promise && promise.then) {
            promise.then(function() {
              showPause();
              try { video.muted = false; } catch(e) {}
            }).catch(function(e) { console.warn('Testimonial play failed:', e); });
          }
        }

        function doPause() {
          video.pause();
          showPlay();
        }

        playBtn.addEventListener('click', function(e) { e.stopPropagation(); doPlay(); });
        pauseBtn.addEventListener('click', function(e) { e.stopPropagation(); doPause(); });
        video.addEventListener('click', function() {
          if (video.paused) doPlay();
          else doPause();
        });
        video.addEventListener('ended', showPlay);
      });
    });
  </script>

  <Footer />
</Layout>
