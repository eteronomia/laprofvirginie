---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WaveDivider from '../components/WaveDivider.astro';
---

<Layout title="La Prof Virginie — Your Online French Teacher">
  <Navbar currentPage="/" />

  <!-- ============================================ -->
  <!-- SECTION 1: HERO                              -->
  <!-- ============================================ -->
  <!-- MOBILE HERO: image visible, text below -->
  <section class="relative overflow-hidden lg:hidden">
    <div class="relative">
      <img src="/images/hero.jpg" alt="Virginie — French Teacher" class="w-full aspect-[3/4] object-cover object-top" loading="eager" />
      <!-- Bottom gradient fade into content -->
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-cream to-transparent"></div>
    </div>
    <div class="relative bg-cream px-6 pb-8 -mt-16 z-10">
      <div class="reveal">
        <p class="text-teal font-medium text-sm uppercase tracking-[0.15em] mb-3">Certified French Teacher</p>
        <h1 class="text-3xl font-bold text-charcoal leading-[1.1] mb-4">
          Boost Your<br/>
          <span class="text-highlight">Confidence</span><br/>
          in French
        </h1>
        <p class="text-charcoal/75 text-base leading-relaxed mb-5 font-light">
          Personalised coaching with a Certified French Teacher. Learn to speak French naturally, precisely, and with confidence.
        </p>
        <div class="flex flex-wrap gap-3 mb-6">
          <a href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/laprofvirginie/15min?hide_gdpr_banner=1'});return false;" class="btn-primary cursor-pointer">
            Book a Free Call
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#coaching" class="btn-secondary">
            See My Courses
          </a>
        </div>
        <!-- Social proof stats -->
        <div class="grid grid-cols-3 gap-3 pt-5 border-t border-charcoal/10">
          <div class="text-center">
            <p class="text-xl font-bold text-charcoal">80K+</p>
            <p class="text-charcoal/50 text-xs">Instagram Followers</p>
          </div>
          <div class="text-center">
            <p class="text-xl font-bold text-charcoal">300+</p>
            <p class="text-charcoal/50 text-xs">Students Coached</p>
          </div>
          <div class="text-center">
            <p class="text-xl font-bold text-charcoal">10+</p>
            <p class="text-charcoal/50 text-xs">Years of Experience</p>
          </div>
        </div>
      </div>
    </div>
    <WaveDivider color="#F5F0E8" position="bottom" />
  </section>

  <!-- DESKTOP HERO: glass panel over background image (unchanged) -->
  <section class="relative min-h-[90vh] items-center overflow-hidden hidden lg:flex">
    <!-- Background image — NO blur, NO opacity overlay -->
    <div class="absolute inset-0 z-0">
      <img src="/images/hero.jpg" alt="" class="w-full h-full object-cover object-top parallax-bg" loading="eager" />
      <!-- Very subtle bottom fade for wave transition only -->
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-cream to-transparent"></div>
    </div>

    <!-- Hero Content — LEFT side only, does NOT cover Virginie's face -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 lg:py-0 mt-16 w-full">
      <div class="max-w-lg lg:max-w-xl">
        <div class="glass liquid-glass p-8 sm:p-10 reveal" style="background: rgba(255,255,255,0.55); backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%);">
          <p class="text-teal font-medium text-sm uppercase tracking-[0.15em] mb-4">Certified French Teacher</p>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal leading-[1.1] mb-5">
            Boost Your<br/>
            <span class="text-highlight">Confidence</span><br/>
            in French
          </h1>
          <p class="text-charcoal/75 text-base sm:text-lg leading-relaxed mb-6 font-light">
            Personalised coaching with a Certified French Teacher. Learn to speak French naturally, precisely, and with confidence.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/laprofvirginie/15min?hide_gdpr_banner=1'});return false;" class="btn-primary cursor-pointer">
              Book a Free Call
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#coaching" class="btn-secondary">
              See My Courses
            </a>
          </div>

          <!-- Social proof stats -->
          <div class="grid grid-cols-3 gap-3 mt-6 pt-5 border-t border-charcoal/10">
            <div class="text-center">
              <p class="text-xl sm:text-2xl font-bold text-charcoal">80K+</p>
              <p class="text-charcoal/50 text-xs">Instagram Followers</p>
            </div>
            <div class="text-center">
              <p class="text-xl sm:text-2xl font-bold text-charcoal">300+</p>
              <p class="text-charcoal/50 text-xs">Students Coached</p>
            </div>
            <div class="text-center">
              <p class="text-xl sm:text-2xl font-bold text-charcoal">10+</p>
              <p class="text-charcoal/50 text-xs">Years of Experience</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <WaveDivider color="#F5F0E8" position="bottom" />
  </section>


  <!-- ============================================ -->
  <!-- SECTION 2: MEET VIRGINIE                     -->
  <!-- ============================================ -->
  <section class="section-padding relative overflow-hidden bg-cream" id="about-preview">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: Video + Photo -->
        <div class="reveal flex justify-center">
          <div class="relative">
            <!-- Round video container -->
            <div class="video-round mx-auto" id="hero-video">
              <video
                src="/video/intro.mp4"
                poster="/images/with-students.jpg"
                playsinline
                preload="metadata"
                class="w-full h-full object-cover"
                id="main-video"
                muted
              ></video>
              <!-- Play button overlay — onclick fires global function -->
              <div id="play-overlay" class="absolute inset-0 flex items-center justify-center z-20 cursor-pointer" onclick="window.__playVideo()">
                <div class="w-16 h-16 rounded-full bg-gold/90 flex items-center justify-center shadow-lg hover:scale-110 transition-transform duration-300 pointer-events-none">
                  <svg class="w-7 h-7 text-charcoal ml-1 pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <!-- Pause overlay — onclick fires global function -->
              <div id="pause-overlay" class="video-pause-overlay z-20" onclick="window.__pauseVideo()">
                <div class="w-14 h-14 rounded-full bg-charcoal/60 flex items-center justify-center backdrop-blur-sm pointer-events-none">
                  <svg class="w-6 h-6 text-white pointer-events-none" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                </div>
              </div>
            </div>
            <!-- Video control functions — defined globally, called by onclick above -->
            <script is:inline>
              window.__playVideo = function() {
                var v = document.getElementById('main-video');
                var p = document.getElementById('play-overlay');
                var x = document.getElementById('pause-overlay');
                if (!v) return;
                v.muted = true;
                var promise = v.play();
                if (promise && promise.then) {
                  promise.then(function() {
                    if (p) p.style.display = 'none';
                    if (x) x.classList.add('visible');
                    try { v.muted = false; } catch(e) {}
                  }).catch(function(e) {
                    console.warn('Play failed:', e);
                  });
                }
              };
              window.__pauseVideo = function() {
                var v = document.getElementById('main-video');
                var p = document.getElementById('play-overlay');
                var x = document.getElementById('pause-overlay');
                if (!v) return;
                v.pause();
                if (p) p.style.display = 'flex';
                if (x) x.classList.remove('visible');
              };
              // Video ended handler
              var vid = document.getElementById('main-video');
              if (vid) {
                vid.onended = function() {
                  var p = document.getElementById('play-overlay');
                  var x = document.getElementById('pause-overlay');
                  if (p) p.style.display = 'flex';
                  if (x) x.classList.remove('visible');
                };
                // Also allow clicking the video itself to toggle
                vid.onclick = function() {
                  if (vid.paused) { window.__playVideo(); }
                  else { window.__pauseVideo(); }
                };
              }
            </script>
          </div>
        </div>

        <!-- Right: Text -->
        <div class="reveal" style="transition-delay: 0.15s;">
          <div class="glass-clear liquid-glass p-8 sm:p-10">
            <p class="text-gold-dark font-medium text-sm uppercase tracking-[0.15em] mb-3">Meet Your Teacher</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-charcoal mb-6 leading-tight">
              Learn French<br/>with <span class="text-highlight">Virginie</span>
            </h2>
            <div class="space-y-4 text-charcoal/75 leading-relaxed">
              <p>I am Virginie, your Certified French Teacher, and I am passionate about helping my students speak authentic, accurate French.</p>
              <p>Thousands of students follow my lessons on Instagram, and hundreds have gained confidence through my one-on-one personalised coaching.</p>
              <p>My goal is to train you to speak French naturally, while ensuring your language is precise and correct.</p>
            </div>
            <a href="/about" class="btn-primary mt-8 inline-flex">
              Learn More About Me
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <WaveDivider color="#F5F0E8" position="bottom" />
  </section>


  <!-- ============================================ -->
  <!-- SECTION 3: PERSONALISED COACHING             -->
  <!-- ============================================ -->
  <section class="relative section-padding overflow-hidden" id="coaching" style="background: linear-gradient(135deg, #F5F0E8 0%, #EBE6DC 40%, #E5DFCF 70%, #F5F0E8 100%);">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-14 reveal">
        <p class="text-gold-dark font-medium text-sm uppercase tracking-[0.15em] mb-3">Main Program</p>
