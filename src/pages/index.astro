---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="La Prof Virginie — Your Online French Teacher">
  <Navbar currentPage="/" />

  <!-- ============================================ -->
  <!-- SECTION 1: HERO                              -->
  <!-- ============================================ -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Background image with overlay -->
    <div class="absolute inset-0 z-0">
      <img src="/images/hero.jpg" alt="" class="w-full h-full object-cover object-top" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-cream/90 via-cream/70 to-cream/30"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-cream via-transparent to-transparent"></div>
    </div>

    <!-- Floating French decorations -->
    <div class="absolute inset-0 z-1 pointer-events-none overflow-hidden">
      <!-- Eiffel Tower silhouette -->
      <svg class="decoration float w-20 h-20 top-[15%] left-[8%] text-gold" viewBox="0 0 100 140" fill="currentColor" style="animation-delay: 0s;">
        <path d="M50 0 L42 50 L30 130 L25 140 L75 140 L70 130 L58 50 Z M45 60 H55 M40 90 H60 M35 120 H65" stroke="currentColor" stroke-width="2" fill="none"/>
      </svg>
      <!-- Croissant -->
      <svg class="decoration float-reverse w-14 h-14 top-[25%] right-[12%] text-gold" viewBox="0 0 60 40" fill="currentColor" style="animation-delay: 1.5s;">
        <path d="M5 30 Q10 5 30 5 Q50 5 55 30 Q45 20 30 18 Q15 20 5 30Z"/>
      </svg>
      <!-- Beret -->
      <svg class="decoration float-slow w-16 h-16 bottom-[20%] left-[15%] text-gold" viewBox="0 0 60 35" fill="currentColor" style="animation-delay: 3s;">
        <ellipse cx="30" cy="28" rx="28" ry="7"/>
        <path d="M8 28 Q10 10 30 8 Q50 10 52 28"/>
        <circle cx="30" cy="5" r="4"/>
      </svg>
      <!-- Fleur-de-lis accent -->
      <svg class="decoration float w-10 h-10 top-[60%] right-[20%] text-gold" viewBox="0 0 40 50" fill="currentColor" style="animation-delay: 2s;">
        <path d="M20 0 Q25 15 35 20 Q25 25 20 50 Q15 25 5 20 Q15 15 20 0Z"/>
      </svg>
      <!-- Scattered text decorations -->
      <span class="decoration float text-gold font-medium text-lg top-[35%] right-[6%] rotate-12" style="animation-delay: 0.5s; opacity: 0.06;">Bonjour</span>
      <span class="decoration float-reverse text-gold font-medium text-sm bottom-[30%] right-[30%] -rotate-6" style="animation-delay: 2.5s; opacity: 0.05;">Merci</span>
      <span class="decoration float-slow text-gold font-medium text-base top-[70%] left-[5%] rotate-3" style="animation-delay: 1s; opacity: 0.05;">Oui!</span>
    </div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 lg:py-0">
      <div class="max-w-2xl">
        <!-- Glass panel -->
        <div class="glass-strong p-8 sm:p-10 lg:p-12 reveal">
          <p class="text-gold font-medium text-sm uppercase tracking-[0.15em] mb-4">Your Online French Teacher</p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-charcoal leading-[1.1] mb-6">
            Boost Your<br/>
            <span class="text-highlight">Confidence</span><br/>
            in French
          </h1>
          <p class="text-charcoal/80 text-lg sm:text-xl leading-relaxed mb-8 font-light">
            Personalised coaching with a passionate native speaker. Learn to speak French naturally, precisely, and with confidence.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="https://calendly.com/laprofvirginie/15min" target="_blank" rel="noopener" class="btn-primary">
              Book a Free Call
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#coaching" class="btn-secondary">
              See My Courses
            </a>
          </div>

          <!-- Social proof stats -->
          <div class="flex flex-wrap items-center gap-6 mt-8 text-sm text-charcoal/75">
            <div class="flex items-center gap-2">
              <span class="text-2xl font-bold text-gold">1000+</span>
              <span>Instagram<br/>followers</span>
            </div>
            <div class="w-px h-8 bg-charcoal/15 hidden sm:block"></div>
            <div class="flex items-center gap-2">
              <span class="text-2xl font-bold text-gold">100+</span>
              <span>Students<br/>coached</span>
            </div>
            <div class="w-px h-8 bg-charcoal/15 hidden sm:block"></div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <span class="text-2xl font-bold text-gold">5.0</span>
              <span>Student<br/>rating</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-cream to-transparent z-5"></div>
  </section>


  <!-- ============================================ -->
  <!-- SECTION 2: MEET VIRGINIE                     -->
  <!-- ============================================ -->
  <section class="section-padding relative" id="about-preview">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Left: Video + Photo -->
        <div class="reveal flex justify-center">
          <div class="relative">
            <!-- Round video container -->
            <div class="video-round mx-auto" style="width: 320px; height: 320px;">
              <video
                src="/video/intro.mp4"
                poster="/images/about-preview.jpg"
                playsinline
                preload="none"
                class="w-full h-full object-cover cursor-pointer"
                id="intro-video"
                muted
              ></video>
              <!-- Play button overlay -->
              <button id="play-btn" class="absolute inset-0 flex items-center justify-center z-10 group" aria-label="Play intro video">
                <div class="w-16 h-16 rounded-full bg-gold/90 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-charcoal ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </button>
            </div>
            <!-- Gold pulse ring animation -->
            <div class="absolute inset-0 rounded-full" style="width: 320px; height: 320px; animation: pulse-ring 3s ease-out infinite;"></div>
          </div>
        </div>

        <!-- Right: Text -->
        <div class="reveal" style="transition-delay: 0.15s;">
          <div class="glass p-8 sm:p-10">
            <p class="text-gold font-medium text-sm uppercase tracking-[0.15em] mb-3">Meet Your Teacher</p>
            <h2 class="text-3xl sm:text-4xl font-bold text-charcoal mb-6 leading-tight">
              Learn French<br/>with <span class="text-highlight">Virginie</span>
            </h2>
            <div class="space-y-4 text-charcoal/85 leading-relaxed">
              <p>I'm Virginie, your Certified French Teacher, and I'm passionate about helping my students speak authentic, accurate French.</p>
              <p>Thousands of students follow my lessons on Instagram, and hundreds have gained confidence through my one-on-one personalised coaching.</p>
              <p>My goal is to train you to speak French naturally, while ensuring your language is precise and correct.</p>
            </div>
            <a href="/about" class="btn-primary mt-8 inline-flex">
              Learn More About Me
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SECTION 3: PERSONALISED COACHING             -->
  <!-- ============================================ -->
  <section class="relative section-padding overflow-hidden" id="coaching">
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img src="/images/coaching-bg.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-charcoal/75 backdrop-blur-sm"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-14 reveal">
        <p class="text-gold font-medium text-sm uppercase tracking-[0.15em] mb-3">Main Program</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
          1-on-1 Personalised<br/><span class="text-gold">French Coaching</span>
        </h2>
        <p class="text-white/70 text-lg max-w-2xl mx-auto font-light">
          If you want fast progress and lessons tailored exactly to your needs, my personalised coaching sessions are the perfect choice.
        </p>
      </div>

      <!-- Feature cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-14">
        <div class="glass-dark glass-hover p-6 text-center reveal">
          <div class="w-12 h-12 rounded-2xl bg-gold/15 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Tailored to You</h3>
          <p class="text-white/75 text-sm font-light">Sessions customised to your level, learning style and goals</p>
        </div>
        <div class="glass-dark glass-hover p-6 text-center reveal" style="transition-delay: 0.1s;">
          <div class="w-12 h-12 rounded-2xl bg-gold/15 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">50 Min Sessions</h3>
          <p class="text-white/75 text-sm font-light">Focused one-on-one time for maximum progress</p>
        </div>
        <div class="glass-dark glass-hover p-6 text-center reveal" style="transition-delay: 0.2s;">
          <div class="w-12 h-12 rounded-2xl bg-gold/15 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Flexible Schedule</h3>
          <p class="text-white/75 text-sm font-light">Pause or reschedule anytime with 48h notice</p>
        </div>
        <div class="glass-dark glass-hover p-6 text-center reveal" style="transition-delay: 0.3s;">
          <div class="w-12 h-12 rounded-2xl bg-gold/15 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>
          </div>
          <h3 class="text-white font-semibold mb-2">Native Speaker</h3>
          <p class="text-white/75 text-sm font-light">Learn authentic French from a certified native teacher</p>
        </div>
      </div>

      <!-- Pricing cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <!-- Monthly -->
        <div class="pricing-card p-8 reveal">
          <div class="text-center">
            <p class="text-white/60 text-xs uppercase tracking-[0.15em] mb-2">Monthly</p>
            <div class="flex items-baseline justify-center gap-1 mb-1">
              <span class="text-5xl font-bold text-white">400</span>
              <span class="text-white/60 text-lg">EUR/m</span>
            </div>
            <p class="text-white/55 text-sm mb-6">4 sessions per month</p>
            <ul class="text-left space-y-3 mb-8">
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                50-minute individual sessions
              </li>
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Easy credit-card payments via Stripe
              </li>
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Cancel anytime — no commitment
              </li>
            </ul>
            <a href="https://buy.stripe.com/5kQaEWbwv2TJ3wo9NsdIA1F" target="_blank" rel="noopener" class="btn-primary w-full justify-center">Start Now</a>
            <a href="https://calendly.com/laprofvirginie/15min" target="_blank" rel="noopener" class="block text-white/60 text-sm hover:text-gold transition-colors mt-4">
              or book a FREE 15 min call first
            </a>
          </div>
        </div>

        <!-- Quarterly (Featured) -->
        <div class="pricing-card featured p-8 reveal relative" style="transition-delay: 0.15s;">
          <div class="absolute -top-px left-1/2 -translate-x-1/2 px-4 py-1 bg-gold rounded-b-xl">
            <span class="text-charcoal text-xs font-semibold uppercase tracking-wider">Best Value</span>
          </div>
          <div class="text-center pt-4">
            <p class="text-white/60 text-xs uppercase tracking-[0.15em] mb-2">Quarterly</p>
            <div class="flex items-baseline justify-center gap-1 mb-1">
              <span class="text-5xl font-bold text-white">340</span>
              <span class="text-white/60 text-lg">EUR/m</span>
            </div>
            <p class="text-white/55 text-sm mb-1">4 sessions per month — paid quarterly</p>
            <p class="text-gold text-sm font-medium mb-6">Save 60 EUR/month!</p>
            <ul class="text-left space-y-3 mb-8">
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                50-minute individual sessions
              </li>
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Easy credit-card payments via Stripe
              </li>
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Pause classes with 48h notice
              </li>
              <li class="flex items-start gap-3 text-white/70 text-sm">
                <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Biggest savings on coaching
              </li>
            </ul>
            <a href="https://buy.stripe.com/3cIaEW0RR65V2sk1gWdIA1G" target="_blank" rel="noopener" class="btn-primary w-full justify-center">Start Now</a>
            <a href="https://calendly.com/laprofvirginie/15min" target="_blank" rel="noopener" class="block text-white/60 text-sm hover:text-gold transition-colors mt-4">
              or book a FREE 15 min call first
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SECTION 4: ONLINE COURSES                    -->
  <!-- ============================================ -->
  <section class="section-padding relative" id="courses">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14 reveal">
        <p class="text-gold font-medium text-sm uppercase tracking-[0.15em] mb-3">Online Programs</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-charcoal mb-4">
          Learn at <span class="text-highlight">Your Own Pace</span>
        </h2>
        <p class="text-charcoal/75 text-lg max-w-xl mx-auto font-light">
          Prefer to learn on your schedule? My online courses are designed for busy people who want results.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- French Before You Go -->
        <div class="glass glass-hover p-8 reveal">
          <div class="w-14 h-14 rounded-2xl bg-gold/12 flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <span class="inline-block px-3 py-1 bg-gold/10 text-gold text-xs font-semibold rounded-full mb-4">Mini Course</span>
          <h3 class="text-xl font-bold text-charcoal mb-3">French Before You Go</h3>
          <p class="text-charcoal/80 text-sm leading-relaxed mb-6">
            The essentials to get by in France — from ordering a croissant to impressing your friends and the French! Perfect for travellers.
          </p>
          <a href="https://laprofvirginie.teachable.com/p/french-before-you-go1" target="_blank" rel="noopener" class="btn-primary text-sm">
            Join Now
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Master French Grammar -->
        <div class="glass glass-hover p-8 reveal" style="transition-delay: 0.15s;">
          <div class="w-14 h-14 rounded-2xl bg-gold/12 flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <span class="inline-block px-3 py-1 bg-gold/10 text-gold text-xs font-semibold rounded-full mb-4">12-Week Program</span>
          <h3 class="text-xl font-bold text-charcoal mb-3">Master French Grammar & Verbs</h3>
          <p class="text-charcoal/80 text-sm leading-relaxed mb-6">
            Say farewell to verb confusion and hello to fluent, effortless expression. A comprehensive 12-week program to transform your French.
          </p>
          <a href="https://laprofvirginie.teachable.com/p/masterfrenchgrammarverbs" target="_blank" rel="noopener" class="btn-primary text-sm">
            Join Now
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Background decoration -->
    <div class="absolute top-20 right-0 w-72 h-72 bg-gold/5 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-20 left-0 w-56 h-56 bg-gold/4 rounded-full blur-[80px] pointer-events-none"></div>
  </section>


  <!-- ============================================ -->
  <!-- SECTION 5: TESTIMONIALS                      -->
  <!-- ============================================ -->
  <section class="section-padding relative overflow-hidden bg-cream-dark/30">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14 reveal">
        <p class="text-gold font-medium text-sm uppercase tracking-[0.15em] mb-3">Student Stories</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-charcoal mb-4">
          What My Students <span class="text-highlight">Say</span>
        </h2>
      </div>

      <!-- Testimonial cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Michael -->
        <div class="testimonial-card reveal">
          <div class="flex items-center gap-4 mb-5">
            <img src="/images/student-michael.png" alt="Michael" class="w-14 h-14 rounded-full object-cover border-2 border-gold/30" />
            <div>
              <h4 class="font-semibold text-charcoal">Michael</h4>
              <p class="text-charcoal/50 text-sm">England</p>
            </div>
